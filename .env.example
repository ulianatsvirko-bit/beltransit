# Required in Vercel Production, Preview and Development environments.
ADMIN_PASSWORD=replace-with-a-long-unique-password
SESSION_SECRET=replace-with-at-least-32-random-bytes
VPS_API_URL=https://your-secure-vps-api.example.com
VPS_SECRET=replace-with-a-rotated-vps-secret
# Temporary migration switch only. Remove after VPS HTTPS is enabled.
ALLOW_INSECURE_VPS_HTTP=false
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_CHAT_ID=replace-with-telegram-chat-id
